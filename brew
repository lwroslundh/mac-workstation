# 2. Command-Line Utilities
# ----------------------------------------
brew "git"
brew "gh" # GitHub CLI
brew "zsh"
brew "zsh-autosuggestions"
brew "zsh-syntax-highlighting"
brew "fnm" # Fast Node Manager
brew "pnpm"
brew "ffmpeg"
brew "tmux"
brew "jq"
brew "fzf"
brew "ripgrep"
